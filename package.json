{
	"name": "space-and-time",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"pnpm": {
		"overrides": {
			"@mrleebo/prisma-ast": "0.15.0",
			"camelcase": "5",
			"cookie": "0.7.2",
			"esbuild": "0.25.12",
			"lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
			"lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
			"lodash-es@<=4.17.23": ">=4.18.0",
			"lodash@<=4.17.23": ">=4.18.0",
			"happy-dom@20.8.9": "20.8.9",
			"brace-expansion@5.0.5": "5.0.5"
		}
	},
	"scripts": {
		"dev": "vite dev --configLoader native",
		"build": "vite build --configLoader native",
		"preview": "vite preview --configLoader native",
		"prepare": "lefthook install",
		"auth:schema": "pnpm dlx @better-auth/cli@1.5.6 better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check:ci": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write \"**/*.{css,html,js,json,jsonc,md,svelte,ts,yaml,yml}\"",
		"lint": "prettier --check \"**/*.{css,html,js,json,jsonc,md,svelte,ts,yaml,yml}\" && eslint \"**/*.{js,ts,svelte}\"",
		"lint:eslint": "eslint \"**/*.{js,ts}\"",
		"spellcheck": "cspell \"**/*.{js,ts,svelte,md,json,yaml,yml}\" --no-progress",
		"spellcheck:strict": "cspell \"**/*.{js,ts,svelte,md,json,yaml,yml}\" --no-progress --fail-fast",
		"test": "pnpm run test:unit -- --run",
		"test:all": "pnpm run test && pnpm run test:e2e",
		"test:unit": "vitest --config vitest.config.ts --configLoader native",
		"test:e2e": "playwright test --pass-with-no-tests",
		"audit": "pnpm audit",
		"audit:prod": "pnpm audit --prod",
		"audit:fix": "pnpm audit --fix",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"verify": "pnpm run check:ci && pnpm run lint && pnpm run spellcheck && pnpm run test",
		"update:latest": "pnpm update --latest"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.15.1",
		"@neondatabase/serverless": "^1.0.2",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"better-auth": "~1.5.6",
		"cspell": "^9.7.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-sonarjs": "^4.0.2",
		"eslint-plugin-storybook": "^10.3.4",
		"eslint-plugin-svelte": "^3.16.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.4.0",
		"happy-dom": "^20.8.9",
		"lefthook": "^2.1.4",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.4",
		"svelte": "5.55.0",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.5",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@better-auth/infra": "^0.1.13",
		"@better-auth/sso": "1.5.6",
		"cloudinary": "^2.9.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"onFail": "error"
		}
	}
}
